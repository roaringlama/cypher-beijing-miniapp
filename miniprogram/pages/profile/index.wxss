.profile-page { min-height: 100vh; padding-bottom: 165rpx; background: var(--color-ink-950); }
.profile-hero { position: relative; overflow: hidden; padding: 94rpx 32rpx 48rpx; background: radial-gradient(circle at 95% 12%, rgba(215,255,63,0.15), transparent 26%), linear-gradient(155deg, #251735, #100c17 72%); }
.profile-hero::after { position: absolute; right: -140rpx; bottom: -160rpx; width: 450rpx; height: 450rpx; border: 60rpx solid rgba(167,123,255,0.08); border-radius: 50%; content: ""; }
.profile-top, .profile-grid, .social-row, .level-card, .stat-strip, .section-heading, .setting-row, .support-banner, .bottom-nav { display: flex; align-items: center; justify-content: space-between; }
.wordmark { font-size: 34rpx; font-weight: 900; letter-spacing: -2rpx; }
.wordmark text { color: var(--color-tangerine); }
.settings-button { display: flex; width: 72rpx; height: 72rpx; align-items: center; justify-content: center; border: 2rpx solid rgba(255,255,255,0.14); border-radius: 50%; font-size: 24rpx; font-weight: 900; letter-spacing: 3rpx; }
.profile-grid { position: relative; z-index: 2; justify-content: flex-start; gap: 32rpx; margin-top: 54rpx; }
.portrait { position: relative; display: flex; width: 180rpx; height: 200rpx; flex: 0 0 auto; align-items: center; justify-content: center; overflow: hidden; border: 4rpx solid var(--color-paper); border-radius: 50% 50% 46% 54%; background: linear-gradient(145deg, var(--color-violet), #32183e 70%); box-shadow: 12rpx 13rpx 0 var(--color-acid); font-size: 55rpx; font-weight: 900; transform: rotate(-3deg); }
.portrait-rings { position: absolute; width: 150rpx; height: 150rpx; border: 22rpx double rgba(255,255,255,0.1); border-radius: 50%; }
.online { position: absolute; right: 8rpx; bottom: 13rpx; width: 26rpx; height: 26rpx; border: 5rpx solid var(--color-ink-950); border-radius: 50%; background: var(--color-acid); }
.identity { min-width: 0; }
.dancer-name { margin: 12rpx 0 9rpx; font-size: 58rpx; font-weight: 900; line-height: 0.88; letter-spacing: -3rpx; }
.identity-line { color: var(--color-ice); font-size: 19rpx; font-weight: 900; letter-spacing: 1rpx; }
.crew { display: inline-flex; margin-top: 15rpx; padding: 9rpx 14rpx; border: 2rpx solid rgba(255,120,73,0.45); border-radius: var(--radius-pill); color: var(--color-tangerine); font-size: 16rpx; font-weight: 900; }
.bio { position: relative; z-index: 2; margin-top: 42rpx; font-size: 29rpx; font-weight: 800; line-height: 1.45; }
.social-row { position: relative; z-index: 2; margin-top: 26rpx; color: var(--color-muted); font-size: 18rpx; font-weight: 900; }
.social-row button { color: var(--color-paper); font-size: 20rpx; font-weight: 800; }
.social-row button text { margin-left: 7rpx; color: var(--color-acid); font-size: 13rpx; }
.profile-body { padding: 30rpx 32rpx 80rpx; }
.level-card { position: relative; min-height: 190rpx; padding: 25rpx 22rpx; border: 2rpx solid rgba(215,255,63,0.28); border-radius: 28rpx; background: linear-gradient(120deg, rgba(215,255,63,0.09), rgba(167,123,255,0.1)); }
.level-sticker { display: flex; width: 116rpx; height: 126rpx; flex-direction: column; align-items: center; justify-content: center; border-radius: 18rpx 28rpx 22rpx 30rpx; background: var(--color-acid); color: var(--color-ink-950); text-align: center; transform: rotate(-5deg); }
.level-sticker > text { font-size: 27rpx; font-weight: 900; }
.level-sticker > view { margin-top: 6rpx; font-size: 14rpx; font-weight: 900; line-height: 1.05; }
.level-main { min-width: 0; flex: 1; padding: 0 24rpx; }
.level-label { color: var(--color-muted); font-size: 14rpx; font-weight: 900; letter-spacing: 1rpx; }
.points { margin: 8rpx 0 15rpx; font-size: 38rpx; font-weight: 900; }
.points text { color: var(--color-acid); font-size: 15rpx; }
.level-track { height: 8rpx; border-radius: 8rpx; background: rgba(255,255,255,0.1); }
.level-track view { width: 62%; height: 100%; border-radius: 8rpx; background: var(--color-acid); }
.level-main > .muted { display: block; margin-top: 8rpx; font-size: 15rpx; }
.level-note { color: var(--color-tangerine); font-size: 13rpx; font-weight: 900; line-height: 1.05; text-align: right; transform: rotate(7deg); }
.stat-strip { margin-top: 22rpx; padding: 26rpx 0; border-top: 2rpx dashed rgba(255,255,255,0.12); border-bottom: 2rpx dashed rgba(255,255,255,0.12); }
.stat-strip > view { display: flex; flex: 1; flex-direction: column; align-items: center; border-right: 2rpx solid rgba(255,255,255,0.08); }
.stat-strip > view:last-child { border-right: 0; }
.stat-strip text { font-size: 43rpx; font-weight: 900; }
.stat-strip view view { margin-top: 2rpx; color: var(--color-muted); font-size: 14rpx; font-weight: 900; letter-spacing: 1rpx; }
.profile-section { margin-top: 52rpx; }
.section-number { margin-right: 12rpx; color: var(--color-tangerine); font-size: 18rpx; font-weight: 900; }
.section-title { font-size: 24rpx; font-weight: 900; letter-spacing: 2rpx; }
.see-all { color: var(--color-acid); font-size: 17rpx; font-weight: 900; }
.style-stack { margin-top: 22rpx; }
.style-primary { padding: 30rpx; border-radius: 26rpx; background: var(--color-paper); color: var(--color-ink-950); transform: rotate(-1deg); }
.style-primary > text:first-child { color: #776e80; font-size: 14rpx; font-weight: 900; letter-spacing: 2rpx; }
.style-primary > view { margin: 8rpx 0; font-size: 54rpx; font-weight: 900; letter-spacing: -2rpx; }
.style-primary > text:last-child { font-size: 17rpx; font-weight: 800; }
.style-secondary { margin: 12rpx 16rpx 0; padding: 18rpx 24rpx; border: 2rpx solid rgba(255,255,255,0.1); border-radius: 0 0 20rpx 20rpx; color: var(--color-violet); font-size: 21rpx; font-weight: 900; }
.badge-scroll { width: calc(100% + 64rpx); margin: 22rpx -32rpx 0; white-space: nowrap; }
.badge-row { display: inline-flex; gap: 18rpx; padding: 0 32rpx 12rpx; }
.badge-card { display: flex; width: 190rpx; height: 210rpx; flex-direction: column; align-items: center; justify-content: center; border-radius: 28rpx; color: var(--color-ink-950); transform: rotate(-2deg); }
.badge-card view { display: flex; width: 90rpx; height: 90rpx; align-items: center; justify-content: center; border: 5rpx solid currentColor; border-radius: 50%; font-size: 42rpx; font-weight: 900; }
.badge-card text { margin-top: 15rpx; font-size: 18rpx; font-weight: 900; line-height: 1.05; text-align: center; }
.badge-card.acid { background: var(--color-acid); }
.badge-card.violet { background: var(--color-violet); transform: rotate(2deg); }
.badge-card.locked { border: 2rpx dashed rgba(255,255,255,0.18); background: var(--color-ink-900); color: #665c72; transform: none; }
.settings-card { padding: 28rpx; }
.setting-row { width: 100%; padding: 26rpx 0; border-bottom: 2rpx dashed rgba(255,255,255,0.1); text-align: left; }
.setting-row:last-child { border-bottom: 0; }
.setting-row > view:first-child { display: flex; flex-direction: column; font-size: 24rpx; font-weight: 900; }
.setting-row > view:first-child text { margin-top: 5rpx; color: var(--color-muted); font-size: 17rpx; font-weight: 500; }
.switch { width: 84rpx; height: 48rpx; padding: 5rpx; border-radius: 24rpx; background: #3b3046; }
.switch view { width: 38rpx; height: 38rpx; border-radius: 50%; background: var(--color-muted); transition: transform 120ms ease; }
.switch.on { background: var(--color-acid); }
.switch.on view { background: var(--color-ink-950); transform: translateX(36rpx); }
.support-banner { width: 100%; min-height: 150rpx; margin-top: 38rpx; padding: 25rpx 28rpx; border: 2rpx solid rgba(255,120,73,0.4); border-radius: 26rpx; background: rgba(255,120,73,0.07); text-align: left; }
.support-banner > view:first-child { display: flex; flex-direction: column; }
.support-banner > view:first-child text { color: var(--color-tangerine); font-size: 17rpx; font-weight: 900; letter-spacing: 2rpx; }
.support-banner > view:first-child view { margin-top: 8rpx; font-size: 30rpx; font-weight: 900; }
.support-banner > view:last-child { display: flex; width: 68rpx; height: 68rpx; align-items: center; justify-content: center; border-radius: 50%; background: var(--color-tangerine); color: var(--color-ink-950); font-size: 28rpx; font-weight: 900; }
.manifesto { margin-top: 70rpx; color: rgba(255,255,255,0.11); font-size: 62rpx; font-weight: 900; line-height: 0.9; text-align: center; }
.manifesto text { color: rgba(215,255,63,0.16); }
.bottom-nav { position: fixed; z-index: 20; right: 28rpx; bottom: 24rpx; left: 28rpx; height: 116rpx; padding: 0 48rpx; border: 2rpx solid rgba(255,255,255,0.12); border-radius: 58rpx; background: rgba(21,16,33,0.96); box-shadow: 0 20rpx 70rpx rgba(0,0,0,0.45); }
.nav-item { display: flex; width: 100rpx; flex-direction: column; align-items: center; gap: 5rpx; color: var(--color-muted); font-size: 18rpx; font-weight: 900; }
.nav-item.active { color: var(--color-acid); }
.nav-glyph { font-size: 32rpx; }
.nav-create { display: flex; width: 92rpx; height: 92rpx; align-items: center; justify-content: center; border-radius: 50%; background: var(--color-acid); color: var(--color-ink-950); font-size: 58rpx; transform: translateY(-24rpx) rotate(4deg); }
