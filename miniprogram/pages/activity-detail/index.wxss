.detail { min-height: 100vh; padding-bottom: 180rpx; background: var(--color-ink-950); }
.poster { position: relative; height: 760rpx; overflow: hidden; padding: 96rpx 32rpx 40rpx; background: radial-gradient(circle at 80% 25%, rgba(215,255,63,0.22), transparent 27%), linear-gradient(145deg, #34224c, #17101f 55%, #0b0812); }
.poster::before { position: absolute; inset: 0; background-image: linear-gradient(rgba(255,255,255,0.025) 2rpx, transparent 2rpx), linear-gradient(90deg, rgba(255,255,255,0.025) 2rpx, transparent 2rpx); background-size: 44rpx 44rpx; content: ""; }
.poster-glow { position: absolute; right: -120rpx; bottom: -100rpx; width: 520rpx; height: 520rpx; border: 70rpx solid rgba(215,255,63,0.08); border-radius: 50%; box-shadow: 0 0 90rpx rgba(167,123,255,0.25); }
.top-actions { position: relative; z-index: 3; display: flex; justify-content: space-between; }
.round-action { display: flex; width: 76rpx; height: 76rpx; align-items: center; justify-content: center; border: 2rpx solid rgba(255,255,255,0.22); border-radius: 50%; background: rgba(11,8,18,0.55); font-size: 34rpx; font-weight: 800; }
.poster-content { position: absolute; z-index: 2; bottom: 95rpx; left: 32rpx; }
.poster-title { margin-top: 22rpx; font-size: 112rpx; font-weight: 900; line-height: 0.78; letter-spacing: -7rpx; text-shadow: 8rpx 8rpx 0 rgba(0,0,0,0.3); }
.poster-title text { color: var(--color-acid); }
.poster-subtitle { margin-top: 34rpx; color: var(--color-ice); font-size: 22rpx; font-weight: 900; letter-spacing: 2rpx; }
.poster-stamp { position: absolute; z-index: 2; top: 210rpx; right: 42rpx; padding: 18rpx; border: 4rpx solid var(--color-tangerine); color: var(--color-tangerine); font-size: 19rpx; font-weight: 900; line-height: 1.05; text-align: center; transform: rotate(8deg); }
.poster-wave { position: absolute; top: 300rpx; right: -80rpx; color: rgba(255,255,255,0.08); font-size: 100rpx; font-weight: 900; transform: rotate(-70deg); }
.scribble { position: absolute; z-index: 2; right: 34rpx; bottom: 34rpx; color: var(--color-tangerine); font-size: 22rpx; font-weight: 900; transform: rotate(-5deg); }

.detail-body { padding: 0 32rpx; }
.ticket-row { display: flex; margin: -34rpx 0 0; border: 2rpx solid rgba(255,255,255,0.1); border-radius: 24rpx; background: var(--color-paper); box-shadow: var(--shadow-card); color: var(--color-ink-950); transform: rotate(-1deg); }
.ticket-cell { position: relative; display: flex; min-width: 0; flex: 1; flex-direction: column; padding: 26rpx 19rpx; border-right: 2rpx dashed rgba(11,8,18,0.2); }
.ticket-cell.last { border-right: 0; }
.ticket-label { color: #786e82; font-size: 16rpx; font-weight: 900; letter-spacing: 2rpx; }
.ticket-value { margin: 8rpx 0 3rpx; font-size: 26rpx; font-weight: 900; }
.ticket-cell > text:last-child { overflow: hidden; font-size: 18rpx; font-weight: 700; text-overflow: ellipsis; white-space: nowrap; }
.vibe-tags { display: flex; flex-wrap: wrap; gap: 12rpx; margin-top: 42rpx; }
.vibe-tags text { padding: 12rpx 20rpx; border: 2rpx solid rgba(215,255,63,0.35); border-radius: var(--radius-pill); color: var(--color-acid); font-size: 20rpx; font-weight: 900; }
.content-section { margin-top: 56rpx; }
.section-copy { margin-top: 20rpx; font-size: 32rpx; font-weight: 700; line-height: 1.55; }
.host-card { display: flex; align-items: center; margin-top: 54rpx; padding: 28rpx; }
.host-avatar { display: flex; width: 88rpx; height: 88rpx; flex: 0 0 auto; align-items: center; justify-content: center; border-radius: 50%; background: linear-gradient(145deg, var(--color-tangerine), #8c2a4b); font-size: 27rpx; font-weight: 900; transform: rotate(-5deg); }
.host-main { min-width: 0; flex: 1; padding-left: 24rpx; }
.host-label { color: var(--color-acid); font-size: 17rpx; font-weight: 900; letter-spacing: 2rpx; }
.host-name { margin: 5rpx 0; font-size: 30rpx; font-weight: 900; }
.host-main .muted { font-size: 20rpx; }
.reliable-badge { display: flex; width: 92rpx; height: 92rpx; flex-direction: column; align-items: center; justify-content: center; border: 2rpx solid var(--color-ice); border-radius: 50%; color: var(--color-ice); font-size: 22rpx; font-weight: 900; transform: rotate(7deg); }
.reliable-badge text { font-size: 12rpx; }
.info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; }
.info-grid > view { display: flex; min-height: 150rpx; padding: 24rpx 20rpx; border: 2rpx solid rgba(255,255,255,0.08); border-radius: 22rpx; background: rgba(255,255,255,0.03); }
.info-icon { width: 48rpx; color: var(--color-tangerine); font-size: 30rpx; font-weight: 900; }
.info-grid > view > view { display: flex; min-width: 0; flex: 1; flex-direction: column; }
.info-title { font-size: 23rpx; font-weight: 900; }
.info-copy { margin-top: 9rpx; font-size: 20rpx; line-height: 1.4; }
.house-rules { margin-top: 54rpx; }
.rule { display: flex; gap: 22rpx; padding: 24rpx 0; border-bottom: 2rpx dashed rgba(255,255,255,0.12); font-size: 25rpx; }
.rule text { color: var(--color-tangerine); font-size: 18rpx; font-weight: 900; }

.join-dock { position: fixed; z-index: 15; right: 0; bottom: 0; left: 0; display: flex; align-items: center; gap: 26rpx; padding: 20rpx 28rpx 28rpx; border-top: 2rpx solid rgba(255,255,255,0.1); background: rgba(11,8,18,0.97); }
.join-dock > view { flex: 0 0 135rpx; }
.dock-label { color: var(--color-muted); font-size: 16rpx; font-weight: 900; }
.dock-cost { margin-top: 2rpx; font-size: 32rpx; font-weight: 900; }
.dock-cost text { color: var(--color-muted); font-size: 17rpx; }
.join-button { min-width: 0; flex: 1; font-size: 24rpx; }
.join-button.joined { background: var(--color-ice); }

.sheet-backdrop { position: fixed; z-index: 30; inset: 0; display: flex; align-items: flex-end; background: rgba(0,0,0,0.72); }
.join-sheet { width: 100%; padding: 18rpx 32rpx 50rpx; border-radius: 40rpx 40rpx 0 0; background: var(--color-ink-900); animation: rise 220ms ease-out; }
@keyframes rise { from { transform: translateY(100%); } }
.sheet-handle { width: 80rpx; height: 8rpx; margin: 0 auto 34rpx; border-radius: 8rpx; background: rgba(255,255,255,0.2); }
.sheet-title { margin-top: 10rpx; font-size: 48rpx; font-weight: 900; }
.join-summary { display: flex; flex-direction: column; gap: 10rpx; margin: 28rpx 0; padding: 24rpx; border-radius: 20rpx; background: rgba(255,255,255,0.05); font-size: 23rpx; font-weight: 800; }
.join-summary text:last-child { color: var(--color-muted); font-size: 20rpx; }
.promise { display: flex; gap: 18rpx; margin-bottom: 30rpx; }
.promise > text { display: flex; width: 44rpx; height: 44rpx; align-items: center; justify-content: center; border-radius: 50%; background: var(--color-acid); color: var(--color-ink-950); font-weight: 900; }
.promise > view { display: flex; flex: 1; flex-direction: column; font-size: 23rpx; font-weight: 900; }
.promise > view text { margin-top: 8rpx; color: var(--color-muted); font-size: 20rpx; font-weight: 500; line-height: 1.45; }
.not-now { width: 100%; min-height: 76rpx; color: var(--color-muted); font-size: 20rpx; font-weight: 900; letter-spacing: 2rpx; }
