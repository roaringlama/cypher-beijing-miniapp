.home {
  position: relative;
  padding-top: 92rpx;
}

.ambient {
  position: absolute;
  border-radius: 50%;
  filter: blur(60rpx);
  opacity: 0.16;
  pointer-events: none;
}

.ambient-one { top: 100rpx; right: -140rpx; width: 430rpx; height: 430rpx; background: var(--color-violet); }
.ambient-two { top: 760rpx; left: -180rpx; width: 400rpx; height: 400rpx; background: var(--color-acid); opacity: 0.07; }

.topbar, .section-heading, .card-foot, .support-card, .bottom-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.wordmark {
  margin-top: 4rpx;
  font-size: 38rpx;
  font-weight: 900;
  letter-spacing: -2rpx;
}

.wordmark text { color: var(--color-tangerine); }

.avatar-button {
  position: relative;
  display: flex;
  width: 84rpx;
  height: 84rpx;
  align-items: center;
  justify-content: center;
  border: 3rpx solid var(--color-paper);
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-violet), #4c2a71);
  font-size: 26rpx;
  font-weight: 900;
  transform: rotate(4deg);
}

.status-dot { position: absolute; right: -2rpx; bottom: 4rpx; width: 20rpx; height: 20rpx; border: 4rpx solid var(--color-ink-950); border-radius: 50%; background: var(--color-acid); }

.hero { position: relative; margin-top: 72rpx; }
.hero-kicker { color: var(--color-tangerine); font-size: 22rpx; font-weight: 900; line-height: 1.05; letter-spacing: 2rpx; transform: rotate(-2deg); }
.hero .display { position: relative; z-index: 2; width: 600rpx; margin-top: 26rpx; font-size: 94rpx; }
.outline { color: transparent; -webkit-text-stroke: 2rpx var(--color-paper); }
.hero-copy { margin-top: 28rpx; color: var(--color-muted); font-size: 27rpx; }

.vinyl {
  position: absolute;
  top: -12rpx;
  right: -130rpx;
  display: flex;
  width: 360rpx;
  height: 360rpx;
  align-items: center;
  justify-content: center;
  border: 3rpx solid rgba(255, 255, 255, 0.22);
  border-radius: 50%;
  background: repeating-radial-gradient(circle, #181220 0 12rpx, #2a2134 13rpx 15rpx, #120e18 16rpx 26rpx);
  box-shadow: 0 0 70rpx rgba(167, 123, 255, 0.18);
  animation: spin 12s linear infinite;
}

.vinyl-label { display: flex; width: 112rpx; height: 112rpx; align-items: center; justify-content: center; border-radius: 50%; background: var(--color-acid); color: var(--color-ink-950); font-size: 34rpx; font-weight: 900; }
@keyframes spin { to { transform: rotate(360deg); } }

.filter-scroll { width: calc(100% + 64rpx); margin: 58rpx -32rpx 0; white-space: nowrap; }
.filter-row { display: inline-flex; gap: 14rpx; padding: 0 32rpx 10rpx; }
.filter-chip { min-height: 70rpx; padding: 0 28rpx; border: 2rpx solid rgba(255,255,255,0.15); border-radius: var(--radius-pill); color: var(--color-muted); font-size: 22rpx; font-weight: 900; letter-spacing: 1rpx; }
.filter-chip.active { border-color: var(--color-acid); background: var(--color-acid); color: var(--color-ink-950); transform: rotate(-2deg); }

.section-heading { margin: 58rpx 0 24rpx; }
.section-number { margin-right: 12rpx; color: var(--color-tangerine); font-size: 20rpx; font-weight: 900; }
.section-title { font-size: 25rpx; font-weight: 900; letter-spacing: 2rpx; }
.pulse-label { color: var(--color-acid); font-size: 18rpx; font-weight: 800; letter-spacing: 1rpx; }

.activity-list { display: flex; flex-direction: column; gap: 24rpx; }
.activity-card { position: relative; display: flex; width: 100%; min-height: 310rpx; overflow: hidden; border: 2rpx solid rgba(255,255,255,0.09); border-radius: var(--radius-card); background: var(--color-ink-900); text-align: left; box-shadow: var(--shadow-card); }
.activity-card:active { transform: scale(0.985) rotate(-0.5deg); }
.date-stub { display: flex; width: 124rpx; flex: 0 0 auto; flex-direction: column; align-items: center; justify-content: center; color: var(--color-ink-950); }
.tone-acid .date-stub { background: var(--color-acid); }
.tone-tangerine .date-stub { background: var(--color-tangerine); }
.tone-ice .date-stub { background: var(--color-ice); }
.date-day { font-size: 62rpx; font-weight: 900; line-height: 1; }
.date-month { margin-top: 4rpx; font-size: 20rpx; font-weight: 900; letter-spacing: 3rpx; }
.activity-body { position: relative; z-index: 2; display: flex; min-width: 0; flex: 1; flex-direction: column; padding: 30rpx 28rpx 24rpx; }
.activity-meta { display: flex; gap: 10rpx; color: var(--color-ice); font-size: 20rpx; font-weight: 800; letter-spacing: 1rpx; }
.activity-title { margin-top: 18rpx; font-size: 42rpx; font-weight: 900; line-height: 0.98; letter-spacing: -1rpx; }
.tag-row { display: flex; flex-wrap: wrap; gap: 8rpx; margin-top: 22rpx; }
.mini-tag { padding: 7rpx 13rpx; border: 2rpx solid rgba(255,255,255,0.13); border-radius: var(--radius-pill); color: var(--color-muted); font-size: 18rpx; font-weight: 800; }
.card-foot { margin-top: auto; padding-top: 22rpx; border-top: 2rpx dashed rgba(255,255,255,0.1); color: var(--color-muted); font-size: 19rpx; font-weight: 800; }
.spots { color: var(--color-acid); }
.card-wave { position: absolute; right: -18rpx; bottom: 58rpx; color: rgba(255,255,255,0.04); font-size: 90rpx; font-weight: 900; transform: rotate(-12deg); }

.support-card { width: 100%; min-height: 166rpx; margin-top: 28rpx; padding: 28rpx 32rpx; border: 2rpx solid rgba(215,255,63,0.35); border-radius: var(--radius-card); background: linear-gradient(120deg, rgba(215,255,63,0.09), rgba(167,123,255,0.12)); text-align: left; }
.support-kicker { color: var(--color-acid); font-size: 18rpx; font-weight: 900; letter-spacing: 2rpx; }
.support-title { margin-top: 10rpx; font-size: 34rpx; font-weight: 900; }
.support-arrow { display: flex; width: 68rpx; height: 68rpx; align-items: center; justify-content: center; border-radius: 50%; background: var(--color-paper); color: var(--color-ink-950); font-size: 34rpx; }

.bottom-nav { position: fixed; z-index: 20; right: 28rpx; bottom: 24rpx; left: 28rpx; height: 116rpx; padding: 0 48rpx; border: 2rpx solid rgba(255,255,255,0.12); border-radius: 58rpx; background: rgba(21,16,33,0.96); box-shadow: 0 20rpx 70rpx rgba(0,0,0,0.45); }
.nav-item { display: flex; width: 100rpx; flex-direction: column; align-items: center; gap: 5rpx; color: var(--color-muted); font-size: 18rpx; font-weight: 900; letter-spacing: 1rpx; }
.nav-item.active { color: var(--color-acid); }
.nav-glyph { font-size: 32rpx; }
.nav-create { display: flex; width: 92rpx; height: 92rpx; align-items: center; justify-content: center; border-radius: 50%; background: var(--color-acid); box-shadow: 0 0 32rpx rgba(215,255,63,0.25); color: var(--color-ink-950); font-size: 58rpx; font-weight: 400; transform: translateY(-24rpx) rotate(4deg); }
